{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "moduleResolution": "bundler"
  },
  "include": ["src/**/*.js", "src/**/*.svelte"],
  "exclude": ["node_modules"]
}
